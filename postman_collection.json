{
	"info": {
		"name": "StockSniper API",
		"description": "Postman collection for managing the StockSniper bot.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000",
			"type": "string"
		},
		{
			"key": "bearer_token",
			"value": "your_secure_token_here",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Process Management",
			"item": [
				{
					"name": "Start Process",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{bearer_token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/process/start",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"process",
								"start"
							]
						}
					},
					"response": []
				},
				{
					"name": "Stop Process",
					"request": {
						"auth": {
							"type": "bearer",
