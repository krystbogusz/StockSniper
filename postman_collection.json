								}
							]
						},
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/process/restart",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"process",
								"restart"
							]
						}
					},
					"response": []
