								{
									"key": "token",
									"value": "{{bearer_token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/process/health",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"process",
								"health"
							]
						}
					},
					"response": []
				}
			]
		},
